@model DACN_CNPM_QuanLyXayDung.Models.DashboardViewModel

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="p-8 space-y-8">
    <!-- Hero & KPI Section -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-bold text-white">Quản lý dự án &amp; tài nguyên</h2>
            <p class="text-slate-400 mt-1">Hôm nay là @DateTime.Now.ToString("dddd, ngày dd tháng MM năm yyyy"). Chúc bạn một ngày làm việc hiệu quả.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- KPI 1 -->
            <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary/5 rounded-full blur-3xl"></div>
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Dự án đang chạy</p>
                        <h3 class="text-3xl font-bold text-white mt-1">@Model.ActiveProjectsCount</h3>
                    </div>
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-icons">apartment</span>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-2 text-emerald-400 text-xs font-semibold">
                    <span class="material-icons text-sm">trending_up</span>
                    <span>Tracking active projects</span>
                </div>
            </div>
            <!-- KPI 2 -->
            <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Trễ tiến độ</p>
                        <h3 class="text-3xl font-bold text-white mt-1">@Model.DelayedProjectsCount</h3>
                    </div>
                    <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-red-400">
                        <span class="material-icons">schedule</span>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-2 text-red-400 text-xs font-semibold">
                    <span class="material-icons text-sm">warning</span>
                    <span>Cần chú ý gấp</span>
                </div>
            </div>
            <!-- KPI 3 -->
            <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Tổng chi phí</p>
                        <h3 class="text-xl font-bold text-white mt-1">@Model.TotalBudget.ToString("N0")</h3>
                    </div>
                    <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400">
                        <span class="material-icons">payments</span>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-2 text-slate-400 text-xs">
                    <span class="material-icons text-sm">info</span>
                    <span>Tổng ngân sách dự kiến</span>
                </div>
            </div>
            <!-- KPI 4 -->
            <div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Nhân sự (Active)</p>
                        <h3 class="text-3xl font-bold text-white mt-1">@Model.TotalStaff</h3>
                    </div>
                    <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">
                        <span class="material-icons">engineering</span>
                    </div>
                </div>
                <div class="mt-4 flex items-center gap-2 text-emerald-400 text-xs font-semibold">
                    <span class="material-icons text-sm">check_circle</span>
                    <span>Hệ thống quản lý</span>
                </div>
            </div>
        </div>
    </section>
    <!-- Main Dashboard Grid -->
    <div class="grid grid-cols-12 gap-8">
        <!-- Left Column: Project Overview & Gantt -->
        <div class="col-span-8 space-y-8">
            <!-- Project Table -->
            <div class="glass-panel rounded-2xl overflow-hidden">
                <div class="p-6 border-b border-white/10 flex justify-between items-center">
                    <h3 class="text-lg font-bold text-white">Tổng quan dự án</h3>
                    <button class="text-primary text-sm font-semibold hover:underline">Xem tất cả</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-slate-500 text-xs uppercase tracking-wider">
                                <th class="px-6 py-4 font-semibold">ID</th>
                                <th class="px-6 py-4 font-semibold">Tên dự án</th>
                                <th class="px-6 py-4 font-semibold">Tiến độ</th>
                                <th class="px-6 py-4 font-semibold">Trạng thái</th>
                                <th class="px-6 py-4 font-semibold">Quản lý</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            @foreach (var project in Model.ProjectsOverview)
                            {
                                var percent = project.Tasks != null && project.Tasks.Any() ? project.Tasks.Average(t => t.PercentComplete ?? 0) : 0;
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="px-6 py-4 text-sm font-mono text-slate-400">PRJ-@project.ProjectId</td>
                                    <td class="px-6 py-4 text-sm font-semibold text-white">@project.ProjectName</td>
                                    <td class="px-6 py-4 min-w-[140px]">
                                        <div class="flex items-center gap-3">
                                            <div class="flex-1 h-1.5 bg-white/10 rounded-full overflow-hidden">
                                                <div class="h-full bg-primary" style="width: @Math.Round((double)percent)%"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-300">@Math.Round((double)percent)%</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        @if(project.Status == "Planned" || project.Status == "Pending" || project.Status == "Not Started") {
                                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-amber-500/10 text-amber-400 border border-amber-500/20">@project.Status</span>
                                        } else if (project.Status == "Active" || project.Status == "In Progress") {
                                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">@project.Status</span>
                                        } else {
                                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-white/10 text-slate-300 border border-white/20">@project.Status</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <div class="w-8 h-8 rounded-full border-2 border-background-dark bg-slate-700 flex items-center justify-center text-[12px] text-white font-bold" title="@(project.Manager?.FullName ?? "Chưa phân công")">
                                                @(project.Manager != null && !string.IsNullOrEmpty(project.Manager.FullName) ? project.Manager.FullName.Substring(0, 1).ToUpper() : "?")
                                            </div>
                                            <span class="text-xs text-slate-300">@(project.Manager?.FullName ?? "Chưa chỉ định")</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Gantt Chart Preview -->
            <div class="glass-panel rounded-2xl p-6 space-y-6">
                <div class="flex justify-between items-center">
                    <h3 class="text-lg font-bold text-white">Timeline Dự án (Gantt)</h3>
                    <div class="flex gap-2">
                        <button class="px-3 py-1 bg-white/5 rounded-lg text-xs text-slate-300 hover:bg-white/10">Tháng</button>
                        <button class="px-3 py-1 bg-primary/20 rounded-lg text-xs text-primary font-bold">Quý</button>
                        <button class="px-3 py-1 bg-white/5 rounded-lg text-xs text-slate-300 hover:bg-white/10">Năm</button>
                    </div>
                </div>
                <div class="space-y-4">
                    <!-- Months Header -->
                    <div class="grid grid-cols-12 gap-0 border-b border-white/5 pb-2">
                        <div class="col-span-3"></div>
                        <div class="col-span-3 text-center text-[10px] font-bold text-slate-500 uppercase">Tháng 05</div>
                        <div class="col-span-3 text-center text-[10px] font-bold text-slate-500 uppercase border-l border-white/5">Tháng 06</div>
                        <div class="col-span-3 text-center text-[10px] font-bold text-slate-500 uppercase border-l border-white/5">Tháng 07</div>
                    </div>
                    <!-- Projects Timelines -->
                    <div class="space-y-6 relative pt-2">
                        <!-- Vertical Grid Lines -->
                        <div class="absolute inset-y-0 left-1/4 w-px bg-white/5"></div>
                        <div class="absolute inset-y-0 left-1/2 w-px bg-white/5"></div>
                        <div class="absolute inset-y-0 left-3/4 w-px bg-white/5"></div>
                        @foreach (var project in Model.ProjectsTimeline)
                        {
                            var statusColor = project.Status == "Completed" || project.Status == "Done" ? "bg-emerald-400/30 border-emerald-400/40" 
                                            : project.Status == "In Progress" || project.Status == "Active" ? "bg-primary/40 border-primary/40"
                                            : project.Status == "Pending" || project.Status == "Planned" ? "bg-amber-400/30 border-amber-400/40"
                                            : "bg-blue-400/30 border-blue-400/40";
                            <div class="grid grid-cols-12 items-center">
                                <div class="col-span-3 text-sm font-medium text-slate-300 pr-4 truncate" title="@project.ProjectName">@project.ProjectName</div>
                                <div class="col-span-9 relative h-6">
                                    <div class="absolute left-0 top-1 h-4 @statusColor border rounded-full min-w-[10%] w-[50%]" title="@project.Status"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <!-- Right Column: Resources & Risks -->
        <div class="col-span-4 space-y-8">
            <!-- Resource Snapshot -->
            <div class="glass-panel rounded-2xl p-6">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-lg font-bold text-white">Vật tư sắp hết</h3>
                    <span class="material-icons text-slate-500">inventory</span>
                </div>
                <div class="space-y-5">
                    @if (Model.LowStockMaterials != null && Model.LowStockMaterials.Any())
                    {
                        @foreach (var mat in Model.LowStockMaterials)
                        {
                            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-orange-500/10 flex items-center justify-center text-orange-400">
                                        <span class="material-icons">inventory_2</span>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-white">@mat.MaterialName</p>
                                        <p class="text-[10px] text-slate-400 uppercase">Mức tối đa: @mat.MinStockLevel</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm font-bold text-orange-400">Cần nhập thêm</p>
                                    <p class="text-[10px] text-slate-500">Đơn vị: @mat.Unit</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center p-4">
                            <p class="text-sm text-slate-400">Không có vật tư nào sắp hết mức lưu trữ tối thiểu.</p>
                        </div>
                    }
                </div>
                <button class="w-full mt-6 py-2.5 rounded-xl border border-white/10 text-xs font-bold text-slate-300 hover:bg-white/5 transition-colors">Xem báo cáo vật tư</button>
            </div>
            <!-- Risks & Alerts -->
            <div class="glass-panel rounded-2xl p-6">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-lg font-bold text-white">Rủi ro &amp; Cảnh báo</h3>
                    <span class="material-icons text-red-400">gpp_maybe</span>
                </div>
                <div class="space-y-4">
                    <!-- Warning Card 1 -->
                    <div class="p-4 rounded-xl border-l-4 border-red-500 bg-red-500/5 space-y-2">
                        <div class="flex justify-between items-start">
                            <span class="text-xs font-bold text-red-400 uppercase">Vượt ngân sách</span>
                            <span class="text-[10px] text-slate-500">2 giờ trước</span>
                        </div>
                        <p class="text-sm text-slate-200">Dự án <span class="text-white font-semibold">Skyline Tower</span> đã vượt 5.2% chi phí nhân công so với kế hoạch tháng 5.</p>
                        <div class="flex gap-2 pt-1">
                            <button class="text-[10px] px-2 py-1 bg-red-500/20 text-red-400 rounded-md font-bold uppercase">Phê duyệt</button>
                            <button class="text-[10px] px-2 py-1 bg-white/5 text-slate-400 rounded-md font-bold uppercase">Bỏ qua</button>
                        </div>
                    </div>
                    <!-- Warning Card 2 -->
                    <div class="p-4 rounded-xl border-l-4 border-amber-500 bg-amber-500/5 space-y-2">
                        <div class="flex justify-between items-start">
                            <span class="text-xs font-bold text-amber-400 uppercase">Chậm bàn giao</span>
                            <span class="text-[10px] text-slate-500">1 ngày trước</span>
                        </div>
                        <p class="text-sm text-slate-200">Nhà thầu phụ điện chưa hoàn thành lắp đặt tại <span class="text-white font-semibold">Vincom Phase 2</span>.</p>
                        <div class="flex gap-2 pt-1">
                            <button class="text-[10px] px-2 py-1 bg-amber-500/20 text-amber-400 rounded-md font-bold uppercase">Gửi nhắc nhở</button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Weather Info (Nice to have for construction) -->
            <div class="glass-card rounded-2xl p-6 relative overflow-hidden">
                <div class="flex items-center justify-between relative z-10">
                    @if (Model.Weather != null)
                    {
                        <div>
                            <h4 class="text-sm font-bold text-white">@Model.Weather.City</h4>
                            <p class="text-2xl font-bold text-primary mt-1">
                                @Model.Weather.Temperature.ToString("0.#")°C
                            </p>
                            <p class="text-[10px] text-slate-400 uppercase tracking-tight">
                                @Model.Weather.Description - Độ ẩm @Model.Weather.Humidity% · Gió @Model.Weather.WindSpeed.ToString("0.#") m/s
                            </p>
                        </div>
                    }
                    else
                    {
                        <div>
                            <h4 class="text-sm font-bold text-white">Đà Nẵng</h4>
                            <p class="text-sm text-slate-400 mt-1">Không lấy được dữ liệu thời tiết hiện tại.</p>
                        </div>
                    }
                    <span class="material-icons text-4xl text-amber-400">@(Model.Weather?.Icon ?? "wb_sunny")</span>
                </div>
                <div class="absolute -bottom-6 -right-6 opacity-5">
                    <span class="material-icons text-9xl">@(Model.Weather?.Icon ?? "wb_sunny")</span>
                </div>
            </div>
        </div>
    </div>