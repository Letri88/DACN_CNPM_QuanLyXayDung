@model DACN_CNPM_QuanLyXayDung.Models.InventoryTransaction

@{
    ViewData["Title"] = "Chi tiết Giao dịch";
}

<div class="p-8 space-y-8">
    <div class="max-w-3xl mx-auto">
        <div class="glass-card p-8 rounded-2xl relative overflow-hidden">
            <!-- Decorative blur -->
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            
            <div class="flex justify-between items-start mb-8 relative z-10">
                <div>
                    <h3 class="text-2xl font-bold text-white mb-2">Chi tiết Nhập kho</h3>
                    <div class="flex items-center gap-3">
                        <span class="text-sm text-slate-400 font-mono bg-white/5 py-1 px-3 rounded-lg border border-white/10">ID: TX-@Model.TransactionId</span>
                        <span class="px-3 py-1 rounded-full text-xs font-bold uppercase bg-primary/10 text-primary border border-primary/20">@Model.Type</span>
                    </div>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary border border-primary/20 shadow-lg shadow-primary/5">
                    <span class="material-icons text-3xl">add_shopping_cart</span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
                <div class="space-y-6">
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Dự án</p>
                        <p class="text-white font-medium">@Html.DisplayFor(model => model.Project.ProjectName)</p>
                    </div>
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Người phụ trách</p>
                        <div class="flex items-center gap-3 mt-2">
                            @{
                                var roleNameDetail = Model.WarehouseKeeper?.Role?.RoleName?.Trim().ToLower() switch {
                                    "admin" => "Quản trị viên",
                                    "project manager" => "Quản lý dự án",
                                    "engineer" => "Kỹ sư",
                                    "warehouse keeper" => "Thủ kho",
                                    _ => Model.WarehouseKeeper?.Role?.RoleName
                                };
                            }
                            <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-xs font-bold text-white border-2 border-background-dark">
                                @(Model.WarehouseKeeper?.FullName?.Substring(0, 1).ToUpper() ?? "?")
                            </div>
                            <div>
                                <p class="text-white font-medium text-sm">@(Model.WarehouseKeeper?.FullName ?? "Chưa rõ")</p>
                                @if (!string.IsNullOrEmpty(roleNameDetail)) {
                                    <p class="text-[10px] text-slate-400">@roleNameDetail</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-6 bg-white/5 p-5 rounded-xl border border-white/5">
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Vật liệu</p>
                        <p class="text-lg font-bold text-white">@Html.DisplayFor(model => model.Material.MaterialName)</p>
                    </div>
                    <div class="grid grid-cols-2 gap-6 pt-4 border-t border-white/5">
                        <div>
                            <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Số lượng</p>
                            <p class="text-2xl font-bold text-emerald-400">@Html.DisplayFor(model => model.Quantity)</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Ngày giao dịch</p>
                            <p class="text-white font-medium flex items-center gap-2 mt-1">
                                <span class="material-icons text-sm text-slate-400">event</span>
                                @(Model.Date?.ToString("dd/MM/yyyy") ?? "-")
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-6 mt-8 border-t border-white/10 flex items-center justify-between relative z-10">
                <a asp-action="Index" class="text-slate-400 hover:text-white transition-colors text-sm flex items-center gap-2">
                    <span class="material-icons text-sm">arrow_back</span> Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model?.TransactionId" class="bg-white/10 hover:bg-white/20 text-white font-bold py-2.5 px-6 rounded-xl transition-colors flex items-center gap-2 border border-white/10">
                    <span class="material-icons text-sm">edit</span> Chỉnh sửa
                </a>
            </div>
        </div>
    </div>
</div>
