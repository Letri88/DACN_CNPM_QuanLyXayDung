<div>
<p class="text-slate-400 text-sm font-medium">Dự án đang chạy</p>
<h3 class="text-3xl font-bold text-white mt-1">12</h3>
</div>
<div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
<span class="material-icons">apartment</span>
</div>
</div>
<div class="mt-4 flex items-center gap-2 text-emerald-400 text-xs font-semibold">
<span class="material-icons text-sm">trending_up</span>
<span>+2 dự án mới tháng này</span>
</div>
</div>
<!-- KPI 2 -->
<div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
<div class="flex justify-between items-start">
<div>
<p class="text-slate-400 text-sm font-medium">Trễ tiến độ</p>
<h3 class="text-3xl font-bold text-white mt-1">03</h3>
</div>
<div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-red-400">
<span class="material-icons">schedule</span>
</div>
</div>
<div class="mt-4 flex items-center gap-2 text-red-400 text-xs font-semibold">
<span class="material-icons text-sm">warning</span>
<span>Cần chú ý gấp</span>
</div>
</div>
<!-- KPI 3 -->
<div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
<div class="flex justify-between items-start">
<div>
<p class="text-slate-400 text-sm font-medium">Tổng chi phí</p>
<h3 class="text-3xl font-bold text-white mt-1">14.2B</h3>
</div>
<div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400">
<span class="material-icons">payments</span>
</div>
</div>
<div class="mt-4 flex items-center gap-2 text-slate-400 text-xs">
<span class="material-icons text-sm">info</span>
<span>82% ngân sách dự kiến</span>
</div>
</div>
<!-- KPI 4 -->
<div class="glass-card p-6 rounded-2xl relative overflow-hidden group">
<div class="flex justify-between items-start">
<div>
<p class="text-slate-400 text-sm font-medium">Nhân lực</p>
<h3 class="text-3xl font-bold text-white mt-1">458</h3>
</div>
<div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">
<span class="material-icons">engineering</span>
</div>
</div>
<div class="mt-4 flex items-center gap-2 text-emerald-400 text-xs font-semibold">
<span class="material-icons text-sm">check_circle</span>
<span>Đã phân bổ 94%</span>
</div>
</div>
</div>
</section>
