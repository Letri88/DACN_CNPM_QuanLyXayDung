@model DACN_CNPM_QuanLyXayDung.Models.Project

@{
    ViewData["Title"] = "Chi tiết Dự án";
}

<div class="p-8 space-y-8">
    <div class="max-w-3xl mx-auto">
        <div class="glass-card p-8 rounded-2xl relative overflow-hidden">
            <!-- Decorative blur -->
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            
            <div class="flex justify-between items-start mb-8 relative z-10">
                <div>
                    <h3 class="text-2xl font-bold text-white mb-2">@Model.ProjectName</h3>
                    <div class="flex items-center gap-3">
                        <span class="text-sm text-slate-400 font-mono bg-white/5 py-1 px-3 rounded-lg border border-white/10">ID: PRJ-@Model.ProjectId</span>
                        @if (Model.Status == "Planned" || Model.Status == "Pending")
                        {
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase bg-amber-500/10 text-amber-400 border border-amber-500/20">@Model.Status</span>
                        }
                        else if (Model.Status == "Active" || Model.Status == "In Progress")
                        {
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">@Model.Status</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase bg-white/10 text-slate-300 border border-white/20">@Model.Status</span>
                        }
                    </div>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary border border-primary/20 shadow-lg shadow-primary/5">
                    <span class="material-icons text-3xl">construction</span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
                <div class="space-y-6">
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">@Html.DisplayNameFor(model => model.Description)</p>
                        <p class="text-slate-300 text-sm leading-relaxed">@Html.DisplayFor(model => model.Description)</p>
                    </div>
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">@Html.DisplayNameFor(model => model.Manager)</p>
                        <div class="flex items-center gap-3 mt-2">
                            <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-xs font-bold text-white border-2 border-background-dark" title="ID: @(Model.Manager?.UserId.ToString() ?? "?")">
                                @(Model.Manager != null && !string.IsNullOrEmpty(Model.Manager.FullName) ? Model.Manager.FullName.Substring(0, 1).ToUpper() : "?")
                            </div>
                            <div>
                                <p class="text-white font-medium text-sm">@(Model.Manager?.FullName ?? "Chưa chỉ định")</p>
                                @{
                                    var roleNameDetail = Model.Manager?.Role?.RoleName?.Trim().ToLower() switch {
                                        "admin" => "Quản trị viên",
                                        "project manager" => "Quản lý dự án",
                                        "engineer" => "Kỹ sư",
                                        "warehouse keeper" => "Thủ kho",
                                        _ => Model.Manager?.Role?.RoleName
                                    };
                                }
                                @if(!string.IsNullOrEmpty(roleNameDetail)) {
                                    <p class="text-[10px] text-slate-400">@roleNameDetail</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-6 bg-white/5 p-5 rounded-xl border border-white/5">
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">@Html.DisplayNameFor(model => model.Budget)</p>
                        <p class="text-xl font-bold text-emerald-400">@Html.DisplayFor(model => model.Budget)</p>
                    </div>
                    <div class="grid grid-cols-2 gap-6 pt-4 border-t border-white/5">
                        <div>
                            <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">@Html.DisplayNameFor(model => model.StartDate)</p>
                            <p class="text-white font-medium flex items-center gap-2">
                                <span class="material-icons text-sm text-slate-400">event</span>
                                @(Model.StartDate?.ToString("dd/MM/yyyy") ?? "-")
                            </p>
                        </div>
                        <div>
                            <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">@Html.DisplayNameFor(model => model.EndDate)</p>
                            <p class="text-white font-medium flex items-center gap-2">
                                <span class="material-icons text-sm text-slate-400">event_available</span>
                                @(Model.EndDate?.ToString("dd/MM/yyyy") ?? "-")
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-6 mt-8 border-t border-white/10 flex items-center justify-between relative z-10">
                <a asp-action="Index" class="text-slate-400 hover:text-white transition-colors text-sm flex items-center gap-2">
                    <span class="material-icons text-sm">arrow_back</span> Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model?.ProjectId" class="bg-white/10 hover:bg-white/20 text-white font-bold py-2.5 px-6 rounded-xl transition-colors flex items-center gap-2 border border-white/10">
                    <span class="material-icons text-sm">edit</span> Chỉnh sửa
                </a>
            </div>

            <!-- Material Usages Section -->
            <div class="mt-12 relative z-10">
                <div class="flex items-center justify-between mb-6">
                    <h4 class="text-xl font-bold text-white flex items-center gap-2">
                        <span class="material-icons text-emerald-400">inventory_2</span>
                        Chi tiết vật liệu đã sử dụng
                    </h4>
                    <a asp-controller="MaterialUsages" asp-action="Create" asp-route-projectId="@Model?.ProjectId" class="text-sm bg-primary/20 hover:bg-primary/30 text-primary px-4 py-2 rounded-lg flex items-center gap-2 transition-colors border border-primary/20">
                        <span class="material-icons text-sm">add</span> Thêm sử dụng
                    </a>
                </div>

                @if (Model.MaterialUsages != null && Model.MaterialUsages.Any())
                {
                    <div class="overflow-hidden rounded-xl border border-white/10 bg-white/5">
                        <table class="w-full text-left text-sm text-slate-300">
                            <thead class="bg-white/5 text-xs uppercase text-slate-400">
                                <tr>
                                    <th scope="col" class="px-6 py-4 font-medium tracking-wider">Tên vật liệu</th>
                                    <th scope="col" class="px-6 py-4 font-medium tracking-wider">Số lượng dùng</th>
                                    <th scope="col" class="px-6 py-4 font-medium tracking-wider">DVT</th>
                                    <th scope="col" class="px-6 py-4 font-medium tracking-wider">Ngày ghi nhận</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/5">
                                @foreach (var usage in Model.MaterialUsages.OrderByDescending(u => u.Date))
                                {
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="px-6 py-4">@usage.Material?.MaterialName</td>
                                        <td class="px-6 py-4 font-medium text-white">@usage.QuantityUsage</td>
                                        <td class="px-6 py-4">@usage.Material?.Unit</td>
                                        <td class="px-6 py-4 text-slate-400">@(usage.Date?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="bg-white/5 border border-white/10 rounded-xl p-8 text-center">
                        <span class="material-icons text-5xl text-slate-600 mb-3 block">inventory</span>
                        <p class="text-slate-400">Chưa có vật liệu nào được ghi nhận sử dụng cho dự án này.</p>
                    </div>
                }
            </div>

        </div>
    </div>
</div>
