@{
    Layout = null;
    ViewData["Title"] = "Từ chối truy cập";
}
<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StitchConstruct</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0f2323; }
    </style>
</head>
<body class="bg-background-dark text-slate-200 min-h-screen flex items-center justify-center">
    <div class="text-center">
        <h1 class="text-9xl font-bold text-red-500 mb-4">403</h1>
        <h2 class="text-2xl font-semibold text-white mb-2">Truy cập bị từ chối</h2>
        <p class="text-slate-400 mb-8">Bạn không có quyền truy cập vào chức năng hoặc trang này.</p>
        <a href="/" class="bg-primary text-background-dark font-bold px-6 py-3 rounded-xl hover:bg-primary/80 transition shadow-[0_4px_15px_rgba(178,255,255,0.2)]">Về trang chủ</a>
    </div>
</body>
</html>
