@{
    ViewData["Title"] = "Trang chủ";
}

<section class="home-hero mb-5">
    <div class="hero-content text-center py-5">
        <h1 class="display-4 fw-bold text-primary mb-3">Hệ thống Quản lý Xây dựng</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
            Quản lý dự án, công trình, hợp đồng và nhân sự hiệu quả. Theo dõi tiến độ và báo cáo tập trung.
        </p>
    </div>
</section>

