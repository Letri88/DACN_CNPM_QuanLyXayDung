@model DACN_CNPM_QuanLyXayDung.Models.InventoryTransaction

@{
    ViewData["Title"] = "Chỉnh sửa Giao dịch Nhập kho";
}

<div class="p-8 space-y-8">
    <div class="max-w-2xl mx-auto">
        <div class="glass-panel rounded-2xl p-6">
            <h3 class="text-xl font-bold text-white mb-6">Chỉnh sửa Giao dịch Nhập kho</h3>
            <form asp-action="Edit" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4"></div>
                <input type="hidden" asp-for="TransactionId" />
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="MaterialId" class="text-sm font-medium text-slate-300 mb-1 block">Vật liệu</label>
                        <select asp-for="MaterialId" class="bg-[#1a2e2e] border border-white/10 rounded-lg text-white p-2.5 focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all appearance-none" asp-items="ViewBag.MaterialId">
                            <option value="">-- Chọn Vật liệu --</option>
                        </select>
                        <span asp-validation-for="MaterialId" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ProjectId" class="text-sm font-medium text-slate-300 mb-1 block">Dự án</label>
                        <select asp-for="ProjectId" class="bg-[#1a2e2e] border border-white/10 rounded-lg text-white p-2.5 focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all appearance-none" asp-items="ViewBag.ProjectId">
                            <option value="">-- Chọn Dự án --</option>
                        </select>
                        <span asp-validation-for="ProjectId" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Quantity" class="text-sm font-medium text-slate-300 mb-1 block">Số lượng nhập</label>
                        <input asp-for="Quantity" class="bg-white/5 border border-white/10 rounded-lg text-white p-2.5 focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all" />
                        <span asp-validation-for="Quantity" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Type" class="text-sm font-medium text-slate-300 mb-1 block">Loại giao dịch</label>
                        <input asp-for="Type" class="bg-white/5 border border-white/10 rounded-lg text-white p-2.5 focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all" />
                        <span asp-validation-for="Type" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Date" class="text-sm font-medium text-slate-300 mb-1 block">Ngày giao dịch</label>
                        <input asp-for="Date" type="date" class="bg-white/5 border border-white/10 rounded-lg text-white p-2.5 focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all [color-scheme:dark]" />
                        <span asp-validation-for="Date" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="WarehouseKeeperId" class="text-sm font-medium text-slate-300 mb-1 block">Người phụ trách</label>
                        <select asp-for="WarehouseKeeperId" class="bg-[#1a2e2e] border border-white/10 rounded-lg text-white p-2.5 focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all appearance-none" asp-items="ViewBag.WarehouseKeeperId">
                            <option value="">-- Chọn Người phụ trách --</option>
                        </select>
                        <span asp-validation-for="WarehouseKeeperId" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="pt-4 flex items-center justify-between border-t border-white/10 mt-6">
                    <a asp-action="Index" class="text-slate-400 hover:text-white transition-colors text-sm flex items-center gap-2">
                        <span class="material-icons text-sm">arrow_back</span> Quay lại danh sách
                    </a>
                    <button type="submit" class="bg-primary/20 text-primary hover:bg-primary/30 font-bold py-2.5 px-6 rounded-xl transition-colors flex items-center gap-2">
                        <span class="material-icons text-sm">save</span> Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
