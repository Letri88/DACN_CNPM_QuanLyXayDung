@model DACN_CNPM_QuanLyXayDung.Models.User

@{
    ViewData["Title"] = "Chi tiết Người dùng";
}

<div class="p-8 space-y-8">
    <div class="max-w-3xl mx-auto">
        <div class="glass-card p-8 rounded-2xl relative overflow-hidden">
            <!-- Decorative blur -->
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            
            <div class="flex justify-between items-start mb-8 relative z-10">
                <div class="flex items-center gap-5">
                    <div class="w-16 h-16 rounded-full bg-slate-700 flex items-center justify-center text-white text-2xl font-bold border-2 border-white/10 shadow-lg">
                        @(string.IsNullOrEmpty(Model.FullName) ? "?" : Model.FullName.Substring(0, 1).ToUpper())
                    </div>
                    <div>
                        <h3 class="text-2xl font-bold text-white mb-2">@Model.FullName</h3>
                        <div class="flex flex-wrap items-center gap-3">
                            <span class="text-sm text-slate-400 font-mono bg-white/5 py-1 px-3 rounded-lg border border-white/10">UID-@Model.UserId</span>
                            
                            @if(Model.Status == "Active") {
                                <span class="flex items-center gap-1.5 text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-full text-xs font-medium border border-emerald-500/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active
                                </span>
                            } else if (Model.Status == "Inactive") {
                                <span class="flex items-center gap-1.5 text-slate-400 bg-white/10 px-2.5 py-1 rounded-full text-xs font-medium border border-white/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span> Inactive
                                </span>
                            } else {
                                <span class="flex items-center gap-1.5 text-amber-400 bg-amber-500/10 px-2.5 py-1 rounded-full text-xs font-medium border border-amber-500/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> @Model.Status
                                </span>
                            }

                            <span class="px-2.5 py-1 rounded-full text-xs font-bold text-primary bg-primary/10 border border-primary/20 uppercase tracking-wide">
                                @(Model.Role?.RoleName?.Trim().ToLower() switch {
                                    "admin" => "Quản trị viên",
                                    "project manager" => "Quản lý dự án",
                                    "engineer" => "Kỹ sư",
                                    "warehouse keeper" => "Thủ kho",
                                    _ => Model.Role?.RoleName ?? "N/A"
                                })
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
                <div class="space-y-6">
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1 flex items-center gap-2">
                            <span class="material-icons text-sm">badge</span> @Html.DisplayNameFor(model => model.FullName)
                        </p>
                        <p class="text-white font-semibold text-lg">@Html.DisplayFor(model => model.FullName)</p>
                    </div>
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1 flex items-center gap-2">
                            <span class="material-icons text-sm">mail</span> @Html.DisplayNameFor(model => model.Email)
                        </p>
                        <a href="mailto:@Model.Email" class="text-primary hover:text-primary-light transition-colors font-medium">@Html.DisplayFor(model => model.Email)</a>
                    </div>
                </div>

                <div class="space-y-6 bg-white/5 p-5 rounded-xl border border-white/5">
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Thông tin bảo mật</p>
                        <div class="space-y-4">
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase mb-1">@Html.DisplayNameFor(model => model.Password)</p>
                                <div class="flex items-center justify-between bg-black/20 p-2 rounded border border-white/5">
                                    <span class="text-slate-400 font-mono text-sm tracking-widest px-2">••••••••</span>
                                    <span class="text-[10px] bg-white/10 px-2 py-0.5 rounded text-slate-400">Đã mã hóa</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-6 mt-8 border-t border-white/10 flex items-center justify-between relative z-10">
                <a asp-action="Index" class="text-slate-400 hover:text-white transition-colors text-sm flex items-center gap-2">
                    <span class="material-icons text-sm">arrow_back</span> Quay lại list
                </a>
                <a asp-action="Edit" asp-route-id="@Model?.UserId" class="bg-white/10 hover:bg-white/20 text-white font-bold py-2.5 px-6 rounded-xl transition-colors flex items-center gap-2 border border-white/10">
                    <span class="material-icons text-sm">edit</span> Chỉnh sửa hồ sơ
                </a>
            </div>
        </div>
    </div>
</div>
