@model IEnumerable<DACN_CNPM_QuanLyXayDung.Models.Task>

@{
    ViewData["Title"] = "Quản lý Công việc";
}

<div class="p-8 space-y-8">
    <div class="glass-panel rounded-2xl overflow-hidden">
        <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h3 class="text-lg font-bold text-white">Danh sách Công việc</h3>
            <a asp-action="Create" class="px-4 py-2 bg-primary/20 text-primary hover:bg-primary/30 font-bold rounded-xl transition-colors text-sm flex items-center gap-2">
                <span class="material-icons text-sm">add</span> Thêm mới
            </a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-slate-500 text-xs uppercase tracking-wider bg-white/5">
                        <th class="px-6 py-4 font-semibold">@Html.DisplayNameFor(model => model.TaskName)</th>
                        <th class="px-6 py-4 font-semibold">@Html.DisplayNameFor(model => model.Project)</th>
                        <th class="px-6 py-4 font-semibold">@Html.DisplayNameFor(model => model.Stage)</th>
                        <th class="px-6 py-4 font-semibold">@Html.DisplayNameFor(model => model.AssignedUser)</th>
                        <th class="px-6 py-4 font-semibold">Tiến độ</th>
                        <th class="px-6 py-4 font-semibold">@Html.DisplayNameFor(model => model.Status)</th>
                        <th class="px-6 py-4 font-semibold text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5 text-slate-300 text-sm">
                    @foreach (var item in Model) {
                        <tr class="hover:bg-white/5 transition-colors">
                            <td class="px-6 py-4 font-semibold text-white">@Html.DisplayFor(modelItem => item.TaskName)</td>
                            <td class="px-6 py-4">PRJ-@Html.DisplayFor(modelItem => item.Project.ProjectId)</td>
                            <td class="px-6 py-4 border-l border-white/5 relative group cursor-pointer" title="@Html.DisplayFor(modelItem => item.Stage.StageName)">
                                <span class="bg-white/5 px-2 py-1 rounded text-xs text-slate-400 font-mono">STG-@Html.DisplayFor(modelItem => item.Stage.StageId)</span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-slate-700 flex items-center justify-center text-[10px] font-bold text-white">
                                        @(item.AssignedUser?.UserId.ToString() ?? "?")
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 w-32">
                                <div class="flex items-center gap-2">
                                    <div class="flex-1 h-1.5 bg-white/10 rounded-full overflow-hidden">
                                        <div class="h-full bg-primary rounded-full" style="width: @(item.PercentComplete)%"></div>
                                    </div>
                                    <span class="text-xs font-mono">@(item.PercentComplete)%</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                @if(item.Status == "Planned" || item.Status == "Pending" || item.Status == "Not Started") {
                                    <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-amber-500/10 text-amber-400 border border-amber-500/20 whitespace-nowrap">@item.Status</span>
                                } else if (item.Status == "Active" || item.Status == "In Progress") {
                                    <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-blue-500/10 text-blue-400 border border-blue-500/20 whitespace-nowrap">@item.Status</span>
                                } else if (item.Status == "Completed" || item.Status == "Done") {
                                    <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 whitespace-nowrap">@item.Status</span>
                                } else {
                                    <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-white/10 text-slate-300 border border-white/20 whitespace-nowrap">@item.Status</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right flex justify-end gap-2">
                                <a asp-action="Edit" asp-route-id="@item.TaskId" class="w-8 h-8 rounded-lg bg-white/5 hover:bg-white/10 flex items-center justify-center text-slate-300 transition-colors" title="Sửa">
                                    <span class="material-icons text-sm">edit</span>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.TaskId" class="w-8 h-8 rounded-lg bg-white/5 hover:bg-white/10 flex items-center justify-center text-slate-300 transition-colors" title="Chi tiết">
                                    <span class="material-icons text-sm">visibility</span>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.TaskId" class="w-8 h-8 rounded-lg bg-red-500/10 hover:bg-red-500/20 flex items-center justify-center text-red-400 transition-colors" title="Xóa">
                                    <span class="material-icons text-sm">delete</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
