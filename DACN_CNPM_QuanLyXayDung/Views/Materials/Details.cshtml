@model DACN_CNPM_QuanLyXayDung.Models.Material

@{
    ViewData["Title"] = "Chi tiết Vật tư";
}

<div class="p-8 space-y-8">
    <div class="max-w-3xl mx-auto">
        <div class="glass-card p-8 rounded-2xl relative overflow-hidden">
            <!-- Decorative blur -->
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            
            <div class="flex justify-between items-start mb-8 relative z-10">
                <div>
                    <h3 class="text-2xl font-bold text-white mb-2">@Model.MaterialName</h3>
                    <div class="flex items-center gap-3">
                        <span class="text-sm text-slate-400 font-mono bg-white/5 py-1 px-3 rounded-lg border border-white/10">Mã NVL: MAT-@Model.MaterialId</span>
                    </div>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary border border-primary/20 shadow-lg shadow-primary/5">
                    <span class="material-icons text-3xl">inventory_2</span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
                <div class="space-y-6">
                    <div>
                        <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">@Html.DisplayNameFor(model => model.MaterialName)</p>
                        <p class="text-white font-semibold text-lg">@Html.DisplayFor(model => model.MaterialName)</p>
                    </div>
                </div>

                <div class="space-y-6 bg-white/5 p-5 rounded-xl border border-white/5">
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">@Html.DisplayNameFor(model => model.Unit)</p>
                            <span class="px-3 py-1 rounded bg-white/10 border border-white/20 text-white text-sm font-medium">@Html.DisplayFor(model => model.Unit)</span>
                        </div>
                        <div>
                            <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Mức tồn kho tối thiểu</p>
                            <div class="flex items-center gap-2 mt-1">
                                <div class="w-2.5 h-2.5 rounded-full @(Model.MinStockLevel > 100 ? "bg-emerald-500 ring-4 ring-emerald-500/20" : "bg-amber-500 ring-4 ring-amber-500/20")"></div>
                                <span class="font-bold text-lg @(Model.MinStockLevel > 100 ? "text-emerald-400" : "text-amber-400")">@Html.DisplayFor(model => model.MinStockLevel)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-6 mt-8 border-t border-white/10 flex items-center justify-between relative z-10">
                <a asp-action="Index" class="text-slate-400 hover:text-white transition-colors text-sm flex items-center gap-2">
                    <span class="material-icons text-sm">arrow_back</span> Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model?.MaterialId" class="bg-white/10 hover:bg-white/20 text-white font-bold py-2.5 px-6 rounded-xl transition-colors flex items-center gap-2 border border-white/10">
                    <span class="material-icons text-sm">edit</span> Chỉnh sửa
                </a>
            </div>
        </div>
    </div>
</div>
